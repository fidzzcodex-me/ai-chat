{
  "functions": {
    "api/chat.js": { "memory": 512, "maxDuration": 30 },
    "api/auth.js": { "memory": 256, "maxDuration": 10 },
    "api/user.js": { "memory": 256, "maxDuration": 10 }
  },
  "rewrites": [
    { "source": "/api/chat", "destination": "/api/chat.js" },
    { "source": "/api/auth/:path*", "destination": "/api/auth.js" },
    { "source": "/api/user", "destination": "/api/user.js" },
    { "source": "/chat", "destination": "/public/chat.html" },
    { "source": "/login", "destination": "/public/login.html" },
    { "source": "/", "destination": "/public/index.html" },
    { "source": "/(.*)", "destination": "/public/$1" }
  ]
}
