{
  "functions": {
    "api/chat.js": { "memory": 512, "maxDuration": 30 },
    "api/auth.js": { "memory": 256, "maxDuration": 10 },
    "api/user.js": { "memory": 256, "maxDuration": 10 }
  },
  "routes": [
    { "src": "/api/chat", "dest": "/api/chat.js" },
    { "src": "/api/auth/(.*)", "dest": "/api/auth.js" },
    { "src": "/api/user", "dest": "/api/user.js" },
    { "src": "/chat", "dest": "/public/chat.html" },
    { "src": "/login", "dest": "/public/login.html" },
    { "src": "/", "dest": "/public/index.html" },
    { "src": "/(.*)\\.html", "dest": "/public/$1.html" },
    { "src": "/(.*)\\.js", "dest": "/public/$1.js" },
    { "src": "/(.*)\\.css", "dest": "/public/$1.css" },
    { "src": "/(.*)", "dest": "/public/index.html" }
  ]
}
