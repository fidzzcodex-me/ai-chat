{
  "functions": {
    "api/chat.js":  { "memory": 512, "maxDuration": 30 },
    "api/auth.js":  { "memory": 256, "maxDuration": 10 },
    "api/user.js":  { "memory": 256, "maxDuration": 10 }
  },
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/api/chat",        "destination": "/api/chat.js"  },
    { "source": "/api/auth/me",     "destination": "/api/auth.js"  },
    { "source": "/api/auth/login",  "destination": "/api/auth.js"  },
    { "source": "/api/auth/register","destination": "/api/auth.js" },
    { "source": "/api/auth/logout", "destination": "/api/auth.js"  },
    { "source": "/api/auth/oauth",  "destination": "/api/auth.js"  },
    { "source": "/api/auth/callback","destination": "/api/auth.js" },
    { "source": "/api/user",        "destination": "/api/user.js"  }
  ]
}
