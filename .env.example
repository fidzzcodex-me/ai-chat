# ─── Supabase ─────────────────────────────────────────────────
# Go to: supabase.com → Project Settings → API
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─── Site URL ─────────────────────────────────────────────────
# Your Vercel deployment URL (no trailing slash)
SITE_URL=https://your-project.vercel.app

# ─── Supabase Auth Setup ──────────────────────────────────────
# In Supabase Dashboard → Authentication → Providers:
#
# Google:
#   - Enable Google provider
#   - Add OAuth redirect URL: https://your-project.vercel.app/api/auth/callback
#   - Add your Google Client ID and Secret
#   - In Google Cloud Console → OAuth consent screen → add your domain
#
# GitHub:
#   - Enable GitHub provider
#   - Add OAuth redirect URL: https://your-project.vercel.app/api/auth/callback
#   - Create GitHub OAuth App at: github.com/settings/developers
#   - Homepage URL: https://your-project.vercel.app
#   - Callback URL: https://your-project.vercel.app/api/auth/callback
#
# ─── Add to Vercel ────────────────────────────────────────────
# Go to: vercel.com → Project → Settings → Environment Variables
# Add each variable above for Production, Preview, and Development
